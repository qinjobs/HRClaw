SCREENING_SERVER_HOST=127.0.0.1
SCREENING_SERVER_PORT=8080
SCREENING_PUBLIC_BASE_URL=http://127.0.0.1:8080
SCREENING_HEALTHCHECK_BASE_URL=http://127.0.0.1:8080

SCREENING_BROWSER_AGENT=playwright
SCREENING_BROWSER_HEADLESS=false
SCREENING_BROWSER_STORAGE_STATE_PATH=data/auth/boss_storage_state.json

SCREENING_BOSS_SEARCH_URL=https://www.zhipin.com/web/chat/search
SCREENING_BOSS_SEARCH_FRAME_NAME=searchFrame
SCREENING_BOSS_SEARCH_FRAME_URL_CONTAINS=/web/frame/search/

SCREENING_BOSS_RECOMMEND_URL=https://www.zhipin.com/web/chat/recommend
SCREENING_BOSS_RECOMMEND_FRAME_NAME=recommendFrame
SCREENING_BOSS_RECOMMEND_FRAME_URL_CONTAINS=/web/frame/recommend/

SCREENING_ENABLE_MODEL_EXTRACTION=false
SCREENING_EXTRACTION_PROVIDER=kimi_cli
SCREENING_EXTRACTION_MODEL=kimi-for-coding
SCREENING_EXTRACTION_RETRIES=1
SCREENING_EXTRACTION_RETRY_DELAY_MS=400

SCREENING_KIMI_CLI_COMMAND=kimi
SCREENING_KIMI_CLI_ARGS=--print --output-format text --final-message-only
SCREENING_KIMI_CLI_TIMEOUT_SECONDS=180

SCREENING_AUTO_GREET_ENABLED=true
SCREENING_AUTO_GREET_THRESHOLD=90
SCREENING_AUTO_GREET_ALLOW_NON_RECOMMEND=0
SCREENING_AUTO_GREET_MAX_PER_TASK=20

SCREENING_SEED_BUILTIN_SCORECARDS=false

SCREENING_RESUME_OCR_PROVIDER=auto
SCREENING_RESUME_OCR_LANG=ch
SCREENING_RESUME_OCR_DET_MODEL_NAME=PP-OCRv5_mobile_det
SCREENING_RESUME_OCR_REC_MODEL_NAME=PP-OCRv5_mobile_rec
SCREENING_RESUME_OCR_FORCE_ON_PDF=false
SCREENING_RESUME_OCR_USE_DOC_ORIENTATION=false
SCREENING_RESUME_OCR_USE_DOC_UNWARPING=false
SCREENING_RESUME_OCR_USE_TEXTLINE_ORIENTATION=false

SCREENING_SEARCH_QDRANT_PATH=data/qdrant_search
SCREENING_SEARCH_EMBEDDING_PROVIDER=hash
SCREENING_SEARCH_SYNC_EXPLAIN=1
